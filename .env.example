# Database (MySQL 8 on VPS / Docker)
# If the password contains @ # % + etc., URL-encode it in DATABASE_URL, or use MYSQL_* vars below.
DATABASE_URL=mysql://storetrace:storetrace@localhost:3306/storetrace
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=storetrace
# MYSQL_PASSWORD=your-plain-password
# MYSQL_DATABASE=storetrace

# Site
NEXT_PUBLIC_SITE_URL=https://storetrace.link
NEXT_PUBLIC_SITE_NAME=StoreTrace

# Server (VPS / PM2 — Next.js listen port; ecosystem.config.cjs defaults to 3001)
# PORT=3001

# Shopify Theme Store affiliate (Partner ref param on "Get theme" links)
# NEXT_PUBLIC_SHOPIFY_THEME_AFFILIATE_REF=your-partner-ref

# Analytics (optional)
# Google Analytics (gtag.js)
NEXT_PUBLIC_GA_ID=G-8GPRHS183R
# NEXT_PUBLIC_CLARITY_ID=xxxxxxxxxx
